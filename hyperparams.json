{
  "_comment": "DFM latent-rollout fluid model hyperparameters (lightweight).",

  "model": {
    "img_size": 256,
    "in_channels": 4,
    "patch_px": 16,

    "d_model": 384,
    "n_slots": 128,
    "n_heads": 8,

    "n_enc_layers": 4,
    "local_attn_radius": 1,

    "n_evo_layers": 4,
    "integrator": "rk2",
    "max_rollout": 64,
    "reencode_every": 2,
    "reencode_every_min": 1,
    "reencode_every_max": 5,

    "n_dec_layers": 4,
    "skip_ch": 32,

    "slot_hierarchy": true,
    "slot_full_prob": 0.25,
    "slot_cutoff_min": 1.0,
    "n_slot_layers": 2,
    "dynamics_hierarchy": true,
    "state_hierarchy": true,

    "latent_noise_std": 0.1,
    "ae_decode_noise_std": 0.05,

    "horizon": 4,
    "horizon_min": 2,
    "horizon_max": 6,
    "horizon_gamma": 1.0,

    "mlp_ratio": 4.0,
    "dropout": 0.0,

    "n_context_frames": 5,
    "ctx_patch_px": 16,
    "d_ctx": 384,
    "n_ctx_tokens": 64,
    "n_ctx_layers": 4,
    "n_ctx_heads": 8,

    "disc_dim": 384,
    "disc_adv_weight": 0.1,
    "disc_lr": 1e-4
  },

  "training": {
    "batch_size": 86,
    "n_epochs": 1000,

    "lr": 1e-4,
    "weight_decay": 1e-5,
    "clip_grad": 1.0,

    "l1_weight": 0.1,
    "latent_loss_weight": 0.1,

    "num_workers": 8,
    "cache_frames": false,
    "compile": true
  }
}
